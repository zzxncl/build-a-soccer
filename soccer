-- ‚ēź‚ēź‚ēź EVENT-DRIVEN AUTO FARM ‚ēź‚ēź‚ēź
-- Flow: Roll ‚Üí wait for RollResult ‚Üí Pick best ‚Üí wait for TeamUpdate ‚Üí Roll again
-- When RunComplete fires ‚Üí Restart ‚Üí Roll again

local function pickBestCard(data)
    if not data or not data.reveals then return end

    local bestPos, bestOVR = nil, 0
    for pos, card in pairs(data.reveals) do
        -- Only pick if that position is placeable
        if data.placeable and data.placeable[pos] then
            if card.ovr and card.ovr > bestOVR then
                bestOVR = card.ovr
                bestPos = pos
            end
        end
    end

    -- If nothing placeable had good OVR, try any placeable position
    if not bestPos then
        for pos, card in pairs(data.reveals) do
            if data.placeable and data.placeable[pos] then
                if card.ovr and card.ovr > bestOVR then
                    bestOVR = card.ovr
                    bestPos = pos
                end
            end
        end
    end

    if bestPos then
        S.totalPicks = S.totalPicks + 1
        if bestOVR > S.bestPull then S.bestPull = bestOVR end
        PickPlayer:FireServer(bestPos)
        return true
    end
    return false
end

local function doNextRoll()
    if not S.autoFarm then return end
    S.waitingForResult = true
    task.wait(0.5)
    RollRequest:FireServer()
    S.totalRolls = S.totalRolls + 1
end

-- Listen for RollResult ‚Üí auto pick
RollResult.OnClientEvent:Connect(function(data)
    S.lastReveals = data
    S.waitingForResult = false

    if S.autoFarm and data and data.reveals then
        task.wait(0.3)
        pickBestCard(data)
    end
end)

-- Listen for TeamUpdate ‚Üí trigger next roll
TeamUpdate.OnClientEvent:Connect(function(data)
    S.lastTeam = data

    if S.autoFarm then
        if data.complete then
            -- Run is done, restart
            S.runComplete = true
            task.wait(1)
            RestartRun:FireServer()
            task.wait(1.5)
            S.runComplete = false
            doNextRoll()
        else
            -- Squad not full yet, roll again
            task.wait(0.5)
            doNextRoll()
        end
    end
end)

-- Listen for RunComplete as backup
RunComplete.OnClientEvent:Connect(function()
    if S.autoFarm then
        S.runComplete = true
        task.wait(1)
        RestartRun:FireServer()
        task.wait(1.5)
        S.runComplete = false
        doNextRoll()
    end
end)

-- Listen for rare alerts
RareAlert.OnClientEvent:Connect(function(data)
    if data and data.name then
        local entry = string.format("[%s] %s ‚Üí %s (%d, %s%s)",
            os.date("%H:%M:%S"), data.playerName or "?",
            data.name, data.ovr or 0, data.tierName or "?",
            data.shiny and " ‚ú®" or "")
        table.insert(S.rareLog, 1, entry)
        if #S.rareLog > 50 then table.remove(S.rareLog) end
    end
end)

